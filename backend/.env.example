# LLM configuration for caption -> visual facts parsing.
# Copy this file to ".env" (or export these in your shell) before starting the backend.
#
# Provider: "openai" (OpenAI-compatible chat API) or "anthropic".
LLM_PROVIDER=openai

# API key for the chosen provider.
LLM_API_KEY=

# Model name.
#   openai     e.g. gpt-4o-mini, gpt-4o, deepseek-chat
#   anthropic  e.g. claude-3-5-sonnet-latest
LLM_MODEL=gpt-4o-mini

# Optional base URL override (defaults below if left empty):
#   openai     https://api.openai.com/v1
#   anthropic  https://api.anthropic.com
# Use this to point at OpenAI-compatible gateways (DeepSeek, Together, etc.).
LLM_BASE_URL=

# Request timeout in seconds.
LLM_TIMEOUT=120

# Optional: enable/disable "thinking" (reasoning) for hybrid models such as
# DeepSeek V4 / Qwen3 on SiliconFlow. Only forwarded to the API when set.
# Leave empty for real OpenAI (it rejects unknown params).
# For this pure text-splitting task, disabling it is much faster.
LLM_ENABLE_THINKING=false
